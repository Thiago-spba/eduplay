rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Responsáveis ──
    match /responsaveis/{uid} {
      allow read: if request.auth != null &&
        (request.auth.uid == uid ||
         resource.data.email == request.auth.token.email);
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Log ECA — imutável por lei ──
    match /eca_logs/{logId} {
      allow create: if request.auth != null;
      allow read:   if request.auth != null && resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // ── Crianças ──
    match /criancas/{codigoAcesso} {
      allow create: if request.auth != null && request.resource.data.parentId == request.auth.uid;
      allow read:   if request.auth != null;
      allow update: if request.auth != null &&
        (resource.data.parentId == request.auth.uid ||
         request.resource.data.keys().hasOnly(['trialInicio', 'atualizadoEm', 'mpPreapprovalId', 'assinaturaStatus', 'assinaturaAtiva', 'assinaturaInicio']));
      allow delete: if request.auth != null && request.auth.token.email == "thiago.rpba@gmail.com";
    }

    // ── Progresso ──
    match /progresso/{codigoAcesso} {
      allow read, write: if request.auth != null;
    }

    // ── Missões ──
    match /missoes/{codigoAcesso}/geradas/{missaoId} {
      allow create: if request.auth != null;
      allow read:   if request.auth != null;
      allow update: if request.auth != null &&
        (resource.data.parentId == request.auth.uid ||
         request.resource.data.keys().hasOnly(['trialInicio', 'atualizadoEm', 'mpPreapprovalId', 'assinaturaStatus', 'assinaturaAtiva', 'assinaturaInicio']));
      allow delete: if false;
    }

    // ── Sessões de quiz ──
    match /quizSessions/{sessionId} {
      allow create: if request.auth != null;
      allow read:   if request.auth != null;
      allow update, delete: if false;
    }

    // ── Demos ──
    match /demos/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Podcasts — leitura pública autenticada, escrita só admin ──
    match /podcasts/{podcastId} {
      allow read:   if request.auth != null;
      allow create, update, delete: if request.auth != null &&
        request.auth.token.email == "thiago.rpba@gmail.com";
    }
  }
}




