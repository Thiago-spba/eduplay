rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Responsáveis ──
    // Só o próprio responsável lê e escreve seus dados
    match /responsaveis/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Log ECA — imutável por lei ──
    // Só cria, nunca edita ou deleta
    match /eca_logs/{logId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // ── Crianças ──
    // Pai cria e lê. Criança lê pelo codigoAcesso (auth anônimo)
    match /criancas/{codigoAcesso} {
      allow create: if request.auth != null
        && request.resource.data.parentId == request.auth.uid;
      allow read: if request.auth != null && (
        resource.data.parentId == request.auth.uid ||
        request.auth.uid != null
      );
      allow update: if request.auth != null
        && resource.data.parentId == request.auth.uid;
      allow delete: if false;
    }

    // ── Progresso da criança ──
    // Leitura: pai ou qualquer auth (criança anônima)
    // Escrita: qualquer auth autenticado (criança joga)
    match /progresso/{codigoAcesso} {
      allow read, write: if request.auth != null;
    }

    // ── Missões geradas pelo pai ──
    // Pai escreve. Criança lê.
    match /missoes/{codigoAcesso}/geradas/{missaoId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if false;
    }

    // ── Sessões de quiz ──
    match /quizSessions/{sessionId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow update, delete: if false;
    }

    // ── Demos (auth anônimo) ──
    match /demos/{uid} {
      allow read, write: if request.auth != null
        && request.auth.uid == uid;
    }
  }
}