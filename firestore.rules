rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Responsáveis ──
    match /responsaveis/{uid} {
      // Leitura própria OU por email (para migração de uid após re-login)
      allow read: if request.auth != null &&
        (request.auth.uid == uid ||
         resource.data.email == request.auth.token.email);
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Log ECA — imutável por lei ──
    match /eca_logs/{logId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // ── Crianças ──
    match /criancas/{codigoAcesso} {
      allow create: if request.auth != null
        && request.resource.data.parentId == request.auth.uid;
      allow read: if request.auth != null && (
        resource.data.parentId == request.auth.uid ||
        request.auth.uid != null
      );
      allow update: if request.auth != null
        && (resource.data.parentId == request.auth.uid
            || request.resource.data.parentId == request.auth.uid);
      allow delete: if false;
    }

    // ── Progresso da criança ──
    match /progresso/{codigoAcesso} {
      allow read, write: if request.auth != null;
    }

    // ── Missões geradas pelo pai ──
    match /missoes/{codigoAcesso}/geradas/{missaoId} {
      allow create: if request.auth != null;
      allow read:   if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if false;
    }

    // ── Sessões de quiz ──
    match /quizSessions/{sessionId} {
      allow create: if request.auth != null;
      allow read:   if request.auth != null;
      allow update, delete: if false;
    }

    // ── Demos (auth anônimo) ──
    match /demos/{uid} {
      allow read, write: if request.auth != null
        && request.auth.uid == uid;
    }
  }
}
