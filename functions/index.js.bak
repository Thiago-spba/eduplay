const BIMESTRES_PERMITIDOS  = ['1bimestre', '2bimestre', '3bimestre', '4bimestre']
const TEMA_MAX_CHARS        = 120

// ── Currículo Municipal SP + Paulista (Mantido Intacto) ────────────
